# Telegram Bot Configuration
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_ID=YOUR_ADMIN_ID_HERE

# MongoDB Atlas - REQUIRED for application to work
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/inventory_bot?retryWrites=true&w=majority

# Flask Web Application
PORT=5000
SECRET_KEY=your-secret-key-for-sessions
FLASK_SECRET_KEY=your-alternative-secret-key
WEB_ADMIN_PASSWORD=admin123

# Web Application URL (for Telegram Mini App button)
WEB_APP_URL=https://your-app-name.onrender.com